# Never commit these. They contain your identity and money.
.env
!.env.example
core/config/security.yaml
!core/config/security.yaml.example

# Ignore all generated content in the data vault. 
# Folders are created at runtime by the startup script.
data/*
# Allow Example + Suggestion files
!data/config/suggested_local_models.json

# Ignore internal DB and graph files to prevent leaking research history.
*.db
*.sqlite
*.sqlite3
*.chroma
knowledge_graph.json
core_insights.json

# Ignore tools created by Misaka at runtime; users should forge their own.
tools/generated/*
tools/registry.json

# Ignore local system metrics and personal preference files.
core/config/model_registry.json
core/interfaces/dashboard/static/assets/system-metrics.json
data/ai/history/misakacipher/*

# Standard Python environment and build artifacts.
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
dist/
build/
*.egg-info/

# IDE and Operating System metadata.
.vs/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Modules
modules/aethvion/specter/models/*
modules/misakacipher/*
modules/aethvion/synapse/openseeface/*

# Local Models
LocalModels/*

# Claude Worktrees
.claude/worktrees/*